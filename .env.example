# MindfulTech Environment Variables
# Copy to .env.local and fill in values

# Calendly booking URL
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/mindfultechnology

# Formspree form ID (create at formspree.io)
# Replace 'your-form-id' with your actual form ID
NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/your-form-id

# Docconnect service URL (if using)
NEXT_PUBLIC_DOCONNECT_URL=

# Site URL for sitemap/robots (production)
NEXT_PUBLIC_SITE_URL=https://mindfultech.services
